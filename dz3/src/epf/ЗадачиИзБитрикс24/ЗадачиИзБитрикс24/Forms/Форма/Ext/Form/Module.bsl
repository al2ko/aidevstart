
&НаСервере
Процедура ЗапроситьДанныеНаСервере()

	Если ПолеВывода = Неопределено Тогда
		ПолеВывода = Новый ТекстовыйДокумент;
	КонецЕсли;

	АдресПодключения = СокрЛП(Токен);
	Если ПустаяСтрока(АдресПодключения) Тогда
		ПолеВывода.УстановитьТекст("Укажите полный webhook URL Bitrix24 в поле ""Токен"".");
		Возврат;
	КонецЕсли;

	ПараметрыПодключения = ПараметрыПодключенияBitrix24(АдресПодключения);
	Если ПараметрыПодключения = Неопределено Тогда
		ПолеВывода.УстановитьТекст(
			"Не удалось разобрать webhook URL." + Символы.ПС
			+ "Ожидаемый формат: https://portal.bitrix24.ru/rest/user_id/webhook_key/");
		Возврат;
	КонецЕсли;

	Попытка
		ОтветAPI = ПолучитьОткрытыеЗадачиBitrix24(ПараметрыПодключения);
	Исключение
		ПолеВывода.УстановитьТекст("Ошибка при обращении к Bitrix24:" + Символы.ПС + ОписаниеОшибки());
		Возврат;
	КонецПопытки;

	Если ОтветAPI = Неопределено Тогда
		ПолеВывода.УстановитьТекст("Bitrix24 вернул пустой ответ.");
		Возврат;
	КонецЕсли;

	ПолеВывода.УстановитьТекст(СформироватьТекстЗадач(ОтветAPI, ПараметрыПодключения));

КонецПроцедуры

&НаКлиенте
Процедура ЗапроситьДанные(Команда)
	ЗапроситьДанныеНаСервере();
КонецПроцедуры

&НаСервере
Функция ПараметрыПодключенияBitrix24(АдресПодключения)

	МетодСпискаЗадач = "tasks.task.list";

	Адрес = СокрЛП(АдресПодключения);
	Адрес = СтрЗаменить(Адрес, "https://", "");
	Адрес = СтрЗаменить(Адрес, "http://", "");

	ПозицияRest = СтрНайти(НРег(Адрес), "/rest/");
	Если ПозицияRest = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;

	Сервер = Лев(Адрес, ПозицияRest - 1);
	ПутьRest = Сред(Адрес, ПозицияRest);

	ПозицияПараметров = СтрНайти(ПутьRest, "?");
	Если ПозицияПараметров > 0 Тогда
		ПутьRest = Лев(ПутьRest, ПозицияПараметров - 1);
	КонецЕсли;

	Если Прав(ПутьRest, СтрДлина(МетодСпискаЗадач)) = МетодСпискаЗадач Тогда
		ПутьRest = Лев(ПутьRest, СтрДлина(ПутьRest) - СтрДлина(МетодСпискаЗадач));
	КонецЕсли;

	Если Прав(ПутьRest, 1) <> "/" Тогда
		ПутьRest = ПутьRest + "/";
	КонецЕсли;

	ПутьМетода = ПутьRest + МетодСпискаЗадач;

	Возврат Новый Структура("Сервер, ПутьRest, ПутьМетода", Сервер, ПутьRest, ПутьМетода);

КонецФункции

&НаСервере
Функция ПолучитьОткрытыеЗадачиBitrix24(ПараметрыПодключения)

	РазмерСтраницы = 50;
	НачалоВыборки = 0;
	ВсеЗадачи = Новый Массив;
	ОтветAPI = Неопределено;

	Пока Истина Цикл
		ОтветСтраницы = ПолучитьСтраницуОткрытыхЗадачBitrix24(ПараметрыПодключения, НачалоВыборки);

		Если ОтветСтраницыНекорректный(ОтветСтраницы) Тогда
			Возврат ОтветСтраницы;
		КонецЕсли;

		Если ОтветAPI = Неопределено Тогда
			ОтветAPI = ОтветСтраницы;
		КонецЕсли;

		ЗадачиСтраницы = ОтветСтраницы.result.tasks;
		Для Каждого Задача Из ЗадачиСтраницы Цикл
			ВсеЗадачи.Добавить(Задача);
		КонецЦикла;

		Всего = 0;
		Если ОтветСтраницы.result.Свойство("total", Всего)
			И Всего <= ВсеЗадачи.Количество() Тогда
			Прервать;
		КонецЕсли;

		Если ЗадачиСтраницы.Количество() < РазмерСтраницы Тогда
			Прервать;
		КонецЕсли;

		НачалоВыборки = НачалоВыборки + РазмерСтраницы;
	КонецЦикла;

	Если ОтветAPI <> Неопределено Тогда
		ОтветAPI.result.Вставить("tasks", ВсеЗадачи);
	КонецЕсли;

	Возврат ОтветAPI;

КонецФункции

&НаСервере
Функция ОтветСтраницыНекорректный(ОтветСтраницы)

	Если ОтветСтраницы = Неопределено Тогда
		Возврат Истина;
	КонецЕсли;

	Если ОтветСтраницы.Свойство("error") Тогда
		Возврат Истина;
	КонецЕсли;

	Если Не ОтветСтраницы.Свойство("result") Тогда
		Возврат Истина;
	КонецЕсли;

	Если Не ОтветСтраницы.result.Свойство("tasks") Тогда
		Возврат Истина;
	КонецЕсли;

	Возврат Ложь;

КонецФункции

&НаСервере
Функция ПолучитьСтраницуОткрытыхЗадачBitrix24(ПараметрыПодключения, НачалоВыборки)

	Возврат ВыполнитьМетодBitrix24(
		ПараметрыПодключения,
		"tasks.task.list",
		ТелоЗапросаСпискаЗадач(НачалоВыборки));

КонецФункции

&НаСервере
Функция ВыполнитьМетодBitrix24(ПараметрыПодключения, ИмяМетода, ТелоЗапроса)

	ПортHTTPS = 443;
	ТаймаутСоединения = 30;
	МинимальныйУспешныйКодHTTP = 200;
	МаксимальныйУспешныйКодHTTP = 300;

	Заголовки = Новый Соответствие;
	Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Заголовки.Вставить("Accept", "application/json");

	Запрос = Новый HTTPЗапрос(ПараметрыПодключения.ПутьRest + ИмяМетода, Заголовки);
	Запрос.УстановитьТелоИзСтроки(ТелоЗапроса, КодировкаТекста.UTF8);

	Соединение = Новый HTTPСоединение(
		ПараметрыПодключения.Сервер,
		ПортHTTPS,
		,
		,
		,
		ТаймаутСоединения,
		Новый ЗащищенноеСоединениеOpenSSL);

	Ответ = Соединение.ОтправитьДляОбработки(Запрос);
	ТелоОтвета = Ответ.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);

	Если Ответ.КодСостояния < МинимальныйУспешныйКодHTTP
		Или Ответ.КодСостояния >= МаксимальныйУспешныйКодHTTP Тогда
		ВызватьИсключение "HTTP " + Строка(Ответ.КодСостояния) + ": " + ТелоОтвета;
	КонецЕсли;

	Возврат ПрочитатьОтветJSON(ТелоОтвета);

КонецФункции

&НаСервере
Функция ТелоЗапросаСпискаЗадач(НачалоВыборки)

	СтатусЗавершена = 5;

	Поля = Новый Массив;
	Поля.Добавить("ID");
	Поля.Добавить("TITLE");
	Поля.Добавить("GROUP_ID");
	Поля.Добавить("STATUS");
	Поля.Добавить("REAL_STATUS");
	Поля.Добавить("DEADLINE");
	Поля.Добавить("RESPONSIBLE_ID");
	Поля.Добавить("PRIORITY");

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();

	ЗаписьJSON.ЗаписатьНачалоОбъекта();
	ЗаписьJSON.ЗаписатьИмяСвойства("order");
	ЗаписьJSON.ЗаписатьНачалоОбъекта();
	ЗаписьJSON.ЗаписатьИмяСвойства("GROUP_ID");
	ЗаписьJSON.ЗаписатьЗначение("asc");
	ЗаписьJSON.ЗаписатьИмяСвойства("DEADLINE");
	ЗаписьJSON.ЗаписатьЗначение("asc");
	ЗаписьJSON.ЗаписатьИмяСвойства("PRIORITY");
	ЗаписьJSON.ЗаписатьЗначение("desc");
	ЗаписьJSON.ЗаписатьКонецОбъекта();

	ЗаписьJSON.ЗаписатьИмяСвойства("filter");
	ЗаписьJSON.ЗаписатьНачалоОбъекта();
	ЗаписьJSON.ЗаписатьИмяСвойства("!REAL_STATUS");
	ЗаписьJSON.ЗаписатьЗначение(СтатусЗавершена);
	ЗаписьJSON.ЗаписатьКонецОбъекта();

	ЗаписьJSON.ЗаписатьИмяСвойства("select");
	ЗаписьJSON.ЗаписатьНачалоМассива();
	Для Каждого Поле Из Поля Цикл
		ЗаписьJSON.ЗаписатьЗначение(Поле);
	КонецЦикла;
	ЗаписьJSON.ЗаписатьКонецМассива();

	ЗаписьJSON.ЗаписатьИмяСвойства("start");
	ЗаписьJSON.ЗаписатьЗначение(НачалоВыборки);
	ЗаписьJSON.ЗаписатьКонецОбъекта();

	Возврат ЗаписьJSON.Закрыть();

КонецФункции

