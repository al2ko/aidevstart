&НаСервере
Функция СформироватьТекстЗадач(ОтветAPI, ПараметрыПодключения)

	Если ОтветAPI.Свойство("error") Тогда
		ОписаниеОшибкиAPI = ЗначениеСвойства(ОтветAPI, "error_description");
		Если ПустаяСтрока(ОписаниеОшибкиAPI) Тогда
			ОписаниеОшибкиAPI = ЗначениеСвойства(ОтветAPI, "error");
		КонецЕсли;
		Возврат "Bitrix24 вернул ошибку: " + ОписаниеОшибкиAPI;
	КонецЕсли;

	Если Не ОтветAPI.Свойство("result") Тогда
		Возврат "Bitrix24 вернул ответ без блока result.";
	КонецЕсли;

	РезультатBitrix24 = ОтветAPI.result;
	Если Не РезультатBitrix24.Свойство("tasks") Тогда
		Возврат "Bitrix24 вернул ответ без списка задач.";
	КонецЕсли;

	СписокЗадачBitrix24 = РезультатBitrix24.tasks;
	Если СписокЗадачBitrix24.Количество() = 0 Тогда
		Возврат "Открытых задач не найдено.";
	КонецЕсли;

	ТекстВывода = "Открытые задачи Bitrix24: " + Строка(СписокЗадачBitrix24.Количество()) + Символы.ПС;
	ТекущийПроект = Неопределено;
	КешПроектов = Новый Соответствие;
	КешПользователей = Новый Соответствие;

	Для Каждого ЗадачаBitrix24 Из СписокЗадачBitrix24 Цикл
		Проект = ПредставлениеПроекта(ЗадачаBitrix24, ПараметрыПодключения, КешПроектов);
		Если Проект <> ТекущийПроект Тогда
			ТекущийПроект = Проект;
			ТекстВывода = ТекстВывода + Символы.ПС + Проект + Символы.ПС;
		КонецЕсли;

		ТекстВывода = ТекстВывода + "  #" + ЗначениеСвойства(ЗадачаBitrix24, "id")
			+ " " + ЗначениеСвойства(ЗадачаBitrix24, "title");

		СрокЗадачи = ЗначениеСвойства(ЗадачаBitrix24, "deadline");
		Если Не ПустаяСтрока(СрокЗадачи) Тогда
			ТекстВывода = ТекстВывода + " | срок: " + СрокЗадачи;
		КонецЕсли;

		ОтветственныйЗадачи = ПредставлениеОтветственного(ЗадачаBitrix24, ПараметрыПодключения, КешПользователей);
		Если Не ПустаяСтрока(ОтветственныйЗадачи) Тогда
			ТекстВывода = ТекстВывода + " | ответственный: " + ОтветственныйЗадачи;
		КонецЕсли;

		ТекстВывода = ТекстВывода + Символы.ПС;
	КонецЦикла;

	ВсегоЗадачBitrix24 = ЗначениеСвойства(РезультатBitrix24, "total");
	Если Не ПустаяСтрока(ВсегоЗадачBitrix24) Тогда
		ТекстВывода = ТекстВывода + Символы.ПС + "Всего найдено в Bitrix24: " + ВсегоЗадачBitrix24;
	КонецЕсли;

	Возврат ТекстВывода;

КонецФункции

&НаСервере
Функция ПредставлениеПроекта(Задача, ПараметрыПодключения, КешПроектов)

	ИдентификаторПроекта = ЗначениеСвойства(Задача, "groupId");
	Если ПустаяСтрока(ИдентификаторПроекта) Тогда
		ИдентификаторПроекта = ЗначениеСвойства(Задача, "GROUP_ID");
	КонецЕсли;

	Если ПустаяСтрока(ИдентификаторПроекта) Или ИдентификаторПроекта = "0" Тогда
		Возврат "Без проекта";
	КонецЕсли;

	ПредставлениеПроекта = "";
	Если КешПроектов.Получить(ИдентификаторПроекта) <> Неопределено Тогда
		Возврат КешПроектов.Получить(ИдентификаторПроекта);
	КонецЕсли;

	Попытка
		ОтветПроекта = ВыполнитьМетодBitrix24(
			ПараметрыПодключения,
			"socialnetwork.api.workgroup.get",
			ТелоЗапросаПроекта(ИдентификаторПроекта));

		Если ОтветПроекта <> Неопределено
			И ОтветПроекта.Свойство("result") Тогда
			ПредставлениеПроекта = ЗначениеСвойства(ОтветПроекта.result, "NAME");
		КонецЕсли;
	Исключение
		ПредставлениеПроекта = "";
	КонецПопытки;

	Если ПустаяСтрока(ПредставлениеПроекта) Тогда
		ПредставлениеПроекта = "Проект " + ИдентификаторПроекта;
	КонецЕсли;

	КешПроектов.Вставить(ИдентификаторПроекта, ПредставлениеПроекта);
	Возврат ПредставлениеПроекта;

КонецФункции

&НаСервере
Функция ПредставлениеОтветственного(Задача, ПараметрыПодключения, КешПользователей)

	ИдентификаторПользователя = ЗначениеСвойства(Задача, "responsibleId");
	Если ПустаяСтрока(ИдентификаторПользователя) Тогда
		ИдентификаторПользователя = ЗначениеСвойства(Задача, "RESPONSIBLE_ID");
	КонецЕсли;

	Если ПустаяСтрока(ИдентификаторПользователя) Тогда
		Возврат "";
	КонецЕсли;

	Если КешПользователей.Получить(ИдентификаторПользователя) <> Неопределено Тогда
		Возврат КешПользователей.Получить(ИдентификаторПользователя);
	КонецЕсли;

	ПредставлениеПользователя = "";

	Попытка
		ОтветПользователя = ВыполнитьМетодBitrix24(
			ПараметрыПодключения,
			"user.get",
			ТелоЗапросаПользователя(ИдентификаторПользователя));

		Если ОтветПользователя <> Неопределено
			И ОтветПользователя.Свойство("result")
			И ОтветПользователя.result.Количество() > 0 Тогда
			ПредставлениеПользователя = ПредставлениеПользователяИзДанных(ОтветПользователя.result[0]);
		КонецЕсли;
	Исключение
		ПредставлениеПользователя = "";
	КонецПопытки;

	Если ПустаяСтрока(ПредставлениеПользователя) Тогда
		ПредставлениеПользователя = ИдентификаторПользователя;
	КонецЕсли;

	КешПользователей.Вставить(ИдентификаторПользователя, ПредставлениеПользователя);
	Возврат ПредставлениеПользователя;

КонецФункции

&НаСервере
Функция ПредставлениеПользователяИзДанных(ДанныеПользователя)

	ЧастиИмени = Новый Массив;
	Фамилия = ЗначениеСвойства(ДанныеПользователя, "LAST_NAME");
	Имя = ЗначениеСвойства(ДанныеПользователя, "NAME");
	Отчество = ЗначениеСвойства(ДанныеПользователя, "SECOND_NAME");

	Если Не ПустаяСтрока(Фамилия) Тогда
		ЧастиИмени.Добавить(Фамилия);
	КонецЕсли;
	Если Не ПустаяСтрока(Имя) Тогда
		ЧастиИмени.Добавить(Имя);
	КонецЕсли;
	Если Не ПустаяСтрока(Отчество) Тогда
		ЧастиИмени.Добавить(Отчество);
	КонецЕсли;

	Возврат СтрСоединить(ЧастиИмени, " ");

КонецФункции

