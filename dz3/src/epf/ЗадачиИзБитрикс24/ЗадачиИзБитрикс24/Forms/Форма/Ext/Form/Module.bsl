&НаСервере
Функция ЧисловоеЗначение(Значение)

	СтрокаЗначения = СокрЛП(Строка(Значение));
	Если ПустаяСтрока(СтрокаЗначения) Тогда
		Возврат Значение;
	КонецЕсли;

	Для ИндексСимвола = 1 По СтрДлина(СтрокаЗначения) Цикл
		Если СтрНайти("0123456789", Сред(СтрокаЗначения, ИндексСимвола, 1)) = 0 Тогда
			Возврат Значение;
		КонецЕсли;
	КонецЦикла;

	Возврат Число(СтрокаЗначения);

КонецФункции

&НаСервере
Функция ЗначениеСвойства(Объект, ИмяСвойства)

	Значение = "";
	Если Объект.Свойство(ИмяСвойства, Значение) И Значение <> Неопределено Тогда
		Возврат Строка(Значение);
	КонецЕсли;

	Возврат "";

КонецФункции
